# Virtual environment — contains all installed packages, never commit this
# Anyone cloning your repo just runs pip install -r requirements.txt instead
.venv/

# The actual database file — data is generated at runtime, not source code
data/

# Python auto-generates these cache folders when it runs your code
# They're machine-specific and useless to others
__pycache__/
*.pyc
*.pyo

# Test coverage output files — generated by pytest, not source code
.coverage
coverage.xml
htmlcov/

# macOS creates this hidden file in every folder — nobody wants it
.DS_Store

# VS Code workspace settings — personal to your machine
.vscode/